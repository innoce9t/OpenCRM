# OpenCRM configuration — copy to ".env" and fill in.
# Without any Firestore settings, OpenCRM falls back to the local JSON file
# (server/data/db.json) and needs no setup at all.

# ---- Firestore (optional) -------------------------------------------------
# Provide EITHER a service-account key file OR application-default credentials.

# Option A: path to a Firebase service-account JSON key.
# Download from: Firebase console -> Project settings -> Service accounts ->
# "Generate new private key". Save it somewhere OUTSIDE version control.
# If you drop the file at server/serviceAccount.json it is picked up automatically
# and you can leave this unset.
FIREBASE_SERVICE_ACCOUNT=./server/serviceAccount.json

# Option B: use Google application-default credentials instead of a key file.
# (Leave FIREBASE_SERVICE_ACCOUNT unset if you use this.)
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/adc.json

# Project id — usually read from the key file automatically; set to override.
# FIRESTORE_PROJECT_ID=my-project-id

# Firestore collection that holds boards (default: "boards").
# FIRESTORE_COLLECTION=boards

# ---- AI assistant (chat "Ask AI") -----------------------------------------
# The assistant answers questions about your tasks. With no key it uses a
# built-in engine that reads the boards directly. Add a key to use a real LLM.
# Provider is auto-detected (Gemini preferred); set AI_PROVIDER to force one of
# gemini | claude | local.

# Google Gemini — get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash

# Anthropic Claude (alternative)
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-5

# AI_PROVIDER=gemini

# ---- Google sign-in via Firebase Auth (recommended) -----------------------
# In the Firebase console: Authentication -> Sign-in method -> enable Google.
# Then Project settings -> General -> "Your apps" (Web app) gives you the config
# values below. Paste them here and the "Continue with Google" button appears.
# Handles both sign-in and first-time signup. Add your dev origin
# (http://localhost:5173) under Authentication -> Settings -> Authorized domains.
FIREBASE_API_KEY=
FIREBASE_PROJECT_ID=
FIREBASE_AUTH_DOMAIN=
FIREBASE_APP_ID=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_STORAGE_BUCKET=
# Server-side token verification reuses your service account (see Firestore
# above) or falls back to FIREBASE_PROJECT_ID alone.

# ---- Google sign-in via raw Google Identity Services (alternative) ---------
# Only used if the Firebase config above is NOT set. Create an OAuth 2.0 Client
# ID (type: Web application) at https://console.cloud.google.com/apis/credentials
# and add your app origins to "Authorized JavaScript origins".
GOOGLE_CLIENT_ID=

# ---- Companion dialer (Android) -------------------------------------------
# Shared Bearer key the CRM-Dialler app sends when it POSTs call logs to
# /api/crm/call-logs. Set the same value in the app's Profile screen. Generate
# one with:  node -e "console.log('crm_live_'+require('crypto').randomBytes(16).toString('hex'))"
CRM_INGEST_KEY=

# ---- Server ---------------------------------------------------------------
# PORT=4000
